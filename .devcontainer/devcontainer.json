{
  "name": "Cristopher",
  "image": "mcr.microsoft.com/devcontainers/universal:2-linux",

  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },

  "forwardPorts": [8000, 5173],
  "portsAttributes": {
    "5173": {
      "label": "Cristopher (frontend)",
      "onAutoForward": "openBrowser"
    },
    "8000": {
      "label": "Cristopher (backend API)",
      "onAutoForward": "silent"
    }
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "anthropic.claude-code"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/Cristopher/backend/venv/bin/python",
        "files.exclude": {
          "**/__pycache__": true,
          "**/node_modules": true,
          "**/venv": true
        }
      }
    }
  },

  "remoteEnv": {
    "TRACKER_AUTOSTART": "0"
  }
}
